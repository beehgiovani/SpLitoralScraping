#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper startup script for Unix
# ----------------------------------------------------------------------------

set -e

# Find the project root
basedir=$(dirname "$0")

# Setup the Wrapper properties
WRAPPER_PROPERTIES="$basedir/.mvn/wrapper/maven-wrapper.properties"
MAVEN_PROJECT_JAR="$basedir/.mvn/wrapper/maven-wrapper.jar"

# Download the jar if it doesn't exist
if [ ! -f "$MAVEN_PROJECT_JAR" ]; then
    echo "Downloading Maven Wrapper jar..."
    JAR_URL=$(grep 'wrapperUrl' "$WRAPPER_PROPERTIES" | cut -d'=' -f2)
    curl -sLo "$MAVEN_PROJECT_JAR" "$JAR_URL"
fi

# Find Java
if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

# Run Maven
exec "$JAVACMD" \
  -classpath "$MAVEN_PROJECT_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$basedir" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
